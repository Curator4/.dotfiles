#!/bin/bash
# TTS Stop hook — kills all queued audio, speaks only the final response
[ -f ~/.claude/tts-enabled ] || exit 0

INPUT=$(cat)

# Signal daemon to drop everything
touch /tmp/tts-daemon/stopped

# Read the final response
TEXT=$(echo "$INPUT" | jq -r '.last_assistant_message // empty' 2>/dev/null)
[ -z "$TEXT" ] && exit 0

# Speak it — TTS_KILL_BEFORE_PLAY makes tts_hook.py kill existing audio
# right before playback starts, which triggers the transition chime
cd ~/workspace/ai/qwen-tts
source bin/activate
export TTS_KILL_BEFORE_PLAY=1
export PIPEWIRE_NODE=tts-voice
printf '%s\n' "$TEXT" | python3 tts_hook.py &
