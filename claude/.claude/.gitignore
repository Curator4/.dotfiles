# Ignore everything by default — whitelist what we want to track
*

# Core config files
!.gitignore
!CLAUDE.md
!settings.json
!settings.local.json
!current-vibe
!statusline-command.sh

# TTS config
!tts-enabled
!tts-voice-mode
!tts-voices.json

# Agents, vibes, hooks (custom work worth tracking)
!agents/
!agents/**
!vibes/
!vibes/**
!hooks/
!hooks/**

# Skills moved out (2026-07-11 consolidation): ~/.claude/skills/ is
# symlinks-only. The canonical copies live in ~/.agents/skills (its own
# repo), the mattpocock mirror, or their owning project repo (holly ->
# household-oc). Nothing here is user-authored content anymore; the
# symlink targets are per-machine paths, so keep the whole dir untracked.

# IDE integration
!ide/
!ide/**

# Plugin install state (not the cached repos/data)
!plugins/
!plugins/installed_plugins.json
!plugins/known_marketplaces.json
plugins/marketplaces/
plugins/cache/
plugins/data/
plugins/blocklist.json
plugins/install-counts-cache.json

# Memory (for auto memory system)
!memory/
!memory/**
