# Ignore everything by default — whitelist what we want to track
*

# Core config files
!.gitignore
!CLAUDE.md
!settings.json
!settings.local.json
!current-vibe
!statusline-command.sh

# TTS config
!tts-enabled
!tts-voice-mode
!tts-voices.json

# Agents, vibes, hooks (custom work worth tracking)
!agents/
!agents/**
!vibes/
!vibes/**
!hooks/
!hooks/**

# Skills moved out (2026-07-11 consolidation): ~/.claude/skills/ is
# symlinks-only. The canonical copies live in ~/.agents/skills (its own
# repo), the mattpocock mirror, or their owning project repo (holly ->
# household-oc). Nothing here is user-authored content anymore; the
# symlink targets are per-machine paths, so keep the whole dir untracked.

# IDE integration
!ide/
!ide/**

# Plugins: nothing here is tracked. installed_plugins.json and
# known_marketplaces.json used to be whitelisted, but they're cache
# bookkeeping, not config — Claude Code rebuilds them from settings.json
# (enabledPlugins + extraKnownMarketplaces) and otherwise just churns
# `lastUpdated` timestamps, dirtying the tree every session.

# Memory (for auto memory system)
!memory/
!memory/**
