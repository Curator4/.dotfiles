# Ignore everything by default — whitelist what we want to track
*

# Core config files
!.gitignore
!CLAUDE.md
!settings.json
!settings.local.json
!current-vibe
!statusline-command.sh

# TTS config
!tts-enabled
!tts-voice-mode
!tts-voices.json

# Agents, skills, vibes, hooks (custom work worth tracking)
!agents/
!agents/**
!skills/
!skills/**
!vibes/
!vibes/**
!hooks/
!hooks/**

# Vendor skills — symlinks into upstream mirrors, not user-authored. Re-deny
# after the !skills/** allowlist so they don't leak in as symlink entries
# whose targets are per-machine paths. Sources:
#   ~/.agents/upstream-mattpocock/  — most non-golang vendor skills
#   ~/.agents/skills/               — golang-* family
#   bundled vendor clone w/ own .git — stop-slop
#   ~/workspace/ai/household-oc/... — project-local shared skill (holly)
skills/caveman
skills/diagnose
skills/edit-article
skills/git-guardrails-claude-code
skills/golang-*
skills/grill-me
skills/grill-with-docs
skills/handoff
skills/holly
skills/improve-codebase-architecture
skills/obsidian-vault
skills/stop-slop
skills/tdd
skills/teach
skills/to-issues
skills/to-prd
skills/triage
skills/write-a-skill
skills/zoom-out

# IDE integration
!ide/
!ide/**

# Plugin install state (not the cached repos/data)
!plugins/
!plugins/installed_plugins.json
!plugins/known_marketplaces.json
plugins/marketplaces/
plugins/cache/
plugins/data/
plugins/blocklist.json
plugins/install-counts-cache.json

# Memory (for auto memory system)
!memory/
!memory/**
