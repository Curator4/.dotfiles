; ── AI Companion Bar ─────────────────────────────────────
; Sits at the top of vertical monitor (DP-4, workspace 4)
; Three panels: voice indicator | avatar | dashboard

; ── Variables ────────────────────────────────────────────
(defvar vibe "cyber")
(defvar avatar_image "/home/curator/.claude/vibes/cyber/avatar.jpg")
(defvar speaking false)
(defvar thinking false)
(defvar thinking_stage "")
(defvar current_voice "mustang")
(defvar last_tool "")
(defvar session_active false)

; ── Polling variables ────────────────────────────────────
(defpoll vibe_poll :interval "2s"
  `cat ~/.claude/current-vibe 2>/dev/null || echo "chill"`)

(defpoll voice_poll :interval "2s"
  `cat ~/workspace/ai/qwen-tts/voice.txt 2>/dev/null || echo "unknown"`)

(defpoll speaking_poll :interval "300ms"
  `pgrep -f "python3 tts_hook.py\|python3 stream_tts.py\|python3 -c" >/dev/null 2>&1 && echo true || echo false`)

(defpoll thinking_poll :interval "1s"
  `[ -f /tmp/tts-daemon/thinking-stage ] && cat /tmp/tts-daemon/thinking-stage || echo ""`)

(defpoll session_poll :interval "2s"
  `pgrep -f "claude" >/dev/null 2>&1 && echo true || echo false`)

; ── Voice Indicator (left panel) ─────────────────────────
(defwidget voice-indicator []
  (box :class "voice-panel"
       :orientation "v"
       :valign "center"
       :halign "center"
       :space-evenly false
    ; Pulsing orb when speaking
    (box :class "orb-container"
      (box :class {speaking_poll == "true" ? "orb speaking" : "orb idle"}))
    ; Status text
    (label :class "voice-status"
           :text {speaking_poll == "true" ? "speaking" :
                  thinking_poll != "" ? "thinking" : "listening"})
    ; Voice name
    (label :class "voice-name" :text voice_poll)))

; ── Avatar (center panel) ────────────────────────────────
(defwidget avatar []
  (box :class "avatar-panel"
       :orientation "v"
       :valign "center"
       :halign "center"
       :space-evenly false
    (image :path {"/home/curator/.claude/vibes/${vibe_poll}/avatar.jpg"}
           :image-width 280
           :image-height 280)
    (label :class "vibe-name" :text vibe_poll)))

; ── Dashboard (right panel) ──────────────────────────────
(defwidget dashboard []
  (box :class "dashboard-panel"
       :orientation "v"
       :valign "center"
       :halign "center"
       :space-evenly false
    ; Session status
    (box :class "dash-row"
      (label :class "dash-label" :text "session")
      (label :class "dash-value"
             :text {session_poll == "true" ? "active" : "idle"}))
    ; Current vibe
    (box :class "dash-row"
      (label :class "dash-label" :text "vibe")
      (label :class "dash-value" :text vibe_poll))
    ; Current voice
    (box :class "dash-row"
      (label :class "dash-label" :text "voice")
      (label :class "dash-value" :text voice_poll))
    ; Time
    (box :class "dash-row"
      (label :class "dash-label" :text "time")
      (label :class "dash-value" :text {formattime(EWW_TIME, "%H:%M")}))))

; ── Main Bar ─────────────────────────────────────────────
(defwidget ai-bar []
  (box :class "ai-bar"
       :orientation "v"
       :space-evenly false
    (avatar)
    (voice-indicator)
    (dashboard)))

; ── Window ───────────────────────────────────────────────
(defwindow ai-companion
  :monitor "DP-4"
  :geometry (geometry :x "0px"
                      :y "0px"
                      :width "1420px"
                      :height "600px"
                      :anchor "top center")
  :stacking "fg"
  :exclusive false
  :focusable false
  :namespace "ai-companion"
  (ai-bar))

; ═════════════════════════════════════════════════════════
; ── Themed Timer Bar (top of DP-4, reserves space) ───────
; State source of truth: /tmp/eww-timer/end (epoch seconds).
; Poll script: ~/.config/eww/scripts/timer-state
; Driver:      ~/.config/fish/functions/timer.fish
; ═════════════════════════════════════════════════════════

; Six polls — one per field — using `jq -r` so strings arrive unquoted.
(defpoll t_display  :interval "200ms" :initial "0:00"
  `~/.config/eww/scripts/timer-state | jq -r .display`)
(defpoll t_msg      :interval "1s"    :initial ""
  `~/.config/eww/scripts/timer-state | jq -r .msg`)
(defpoll t_progress :interval "200ms" :initial "0"
  `~/.config/eww/scripts/timer-state | jq -r .progress`)
(defpoll t_phase    :interval "200ms" :initial "idle"
  `~/.config/eww/scripts/timer-state | jq -r .phase`)
(defpoll t_color    :interval "1s"    :initial "red"
  `~/.config/eww/scripts/timer-state | jq -r .color`)

(defwidget timer-bar []
  (box :class "timer-bar timer-c-${t_color} timer-p-${t_phase}"
       :orientation "v"
       :space-evenly false
       :spacing 0
    (centerbox :class "timer-row" :orientation "h"
      (label :class "timer-time" :text t_display :halign "start" :valign "center")
      (box)
      (label :class "timer-msg"  :text t_msg :halign "end" :valign "center"
             :visible {strlength(t_msg) > 0}))
    (progress :class "timer-progress"
              :value t_progress
              :orientation "h")))

(defwindow timer
  :monitor "DP-4"
  :geometry (geometry :x "0px" :y "0px" :width "1440px" :height "140px" :anchor "top center")
  :stacking "fg"
  :exclusive true
  :focusable false
  :namespace "timer"
  (timer-bar))

; ═════════════════════════════════════════════════════════
; ── Household HUD — attention board (focus + live activity) ─
; Focus: the operator's own priorities (declared, AI-curated/injected).
; Activity: what's being worked on now, derived from live Claude Code
; sessions. Both via the `hud` binary.
; ═════════════════════════════════════════════════════════
(defpoll focus_text :interval "30s" :initial "…"
  `/home/curator/workspace/hud/hud focus`)
(defpoll activity_render :interval "150ms" :initial "…"
  `~/.config/eww/scripts/hud-activity-render`)

(defwidget hud-panel []
  (box :class "hud-panel" :orientation "h" :space-evenly true :spacing 48 :valign "center"
    (box :class "hud-section" :orientation "v" :valign "center" :space-evenly false
      (label :class "hud-title" :text "ACTIVITY" :halign "start")
      (label :class "hud-body" :text activity_render :halign "start" :wrap true))
    (box :class "hud-section" :orientation "v" :valign "center" :space-evenly false
      (label :class "hud-title" :text "FOCUS" :halign "start")
      (label :class "hud-body" :text focus_text :halign "start" :wrap true))))

(defwindow hud
  :monitor "DP-4"
  :geometry (geometry :x "0px" :y "0px" :width "1440px" :anchor "top center")
  :stacking "fg"
  :exclusive true
  :focusable false
  :namespace "hud"
  (hud-panel))
