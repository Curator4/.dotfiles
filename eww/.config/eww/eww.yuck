; ── AI Companion Bar ─────────────────────────────────────
; Sits at the top of vertical monitor (DP-4, workspace 4)
; Three panels: voice indicator | avatar | dashboard

; ── Variables ────────────────────────────────────────────
(defvar vibe "cyber")
(defvar avatar_image "/home/curator/.claude/vibes/cyber/avatar.jpg")
(defvar speaking false)
(defvar thinking false)
(defvar thinking_stage "")
(defvar current_voice "mustang")
(defvar last_tool "")
(defvar session_active false)

; ── Polling variables ────────────────────────────────────
(defpoll vibe_poll :interval "2s"
  `cat ~/.claude/current-vibe 2>/dev/null || echo "chill"`)

(defpoll voice_poll :interval "2s"
  `cat ~/workspace/ai/tts-daemon/voice.txt 2>/dev/null || echo "unknown"`)

(defpoll speaking_poll :interval "300ms"
  `~/.config/eww/scripts/tts-speaking`)

(defpoll thinking_poll :interval "1s"
  `[ -f /tmp/tts-daemon/thinking-stage ] && cat /tmp/tts-daemon/thinking-stage || echo ""`)

(defpoll session_poll :interval "2s"
  `pgrep -f "claude" >/dev/null 2>&1 && echo true || echo false`)

; ── Voice Indicator (left panel) ─────────────────────────
(defwidget voice-indicator []
  (box :class "voice-panel"
       :orientation "v"
       :valign "center"
       :halign "center"
       :space-evenly false
    ; Pulsing orb when speaking
    (box :class "orb-container"
      (box :class {speaking_poll == "true" ? "orb speaking" : "orb idle"}))
    ; Status text
    (label :class "voice-status"
           :text {speaking_poll == "true" ? "speaking" :
                  thinking_poll != "" ? "thinking" : "listening"})
    ; Voice name
    (label :class "voice-name" :text voice_poll)))

; ── Avatar (center panel) ────────────────────────────────
(defwidget avatar []
  (box :class "avatar-panel"
       :orientation "v"
       :valign "center"
       :halign "center"
       :space-evenly false
    (image :path {"/home/curator/.claude/vibes/${vibe_poll}/avatar.jpg"}
           :image-width 280
           :image-height 280)
    (label :class "vibe-name" :text vibe_poll)))

; ── Dashboard (right panel) ──────────────────────────────
(defwidget dashboard []
  (box :class "dashboard-panel"
       :orientation "v"
       :valign "center"
       :halign "center"
       :space-evenly false
    ; Session status
    (box :class "dash-row"
      (label :class "dash-label" :text "session")
      (label :class "dash-value"
             :text {session_poll == "true" ? "active" : "idle"}))
    ; Current vibe
    (box :class "dash-row"
      (label :class "dash-label" :text "vibe")
      (label :class "dash-value" :text vibe_poll))
    ; Current voice
    (box :class "dash-row"
      (label :class "dash-label" :text "voice")
      (label :class "dash-value" :text voice_poll))
    ; Time
    (box :class "dash-row"
      (label :class "dash-label" :text "time")
      (label :class "dash-value" :text {formattime(EWW_TIME, "%H:%M")}))))

; ── Main Bar ─────────────────────────────────────────────
(defwidget ai-bar []
  (box :class "ai-bar"
       :orientation "v"
       :space-evenly false
    (avatar)
    (voice-indicator)
    (dashboard)))

; ── Window ───────────────────────────────────────────────
(defwindow ai-companion
  :monitor "DP-4"
  :geometry (geometry :x "0px"
                      :y "0px"
                      :width "1420px"
                      :height "600px"
                      :anchor "top center")
  :stacking "fg"
  :exclusive false
  :focusable false
  :namespace "ai-companion"
  (ai-bar))

; ═════════════════════════════════════════════════════════
; ── Themed Timer Bar (top of DP-4, reserves space) ───────
; State source of truth: /tmp/eww-timer/end (epoch seconds).
; Poll script: ~/.config/eww/scripts/timer-state
; Driver:      ~/.config/fish/functions/timer.fish
; ═════════════════════════════════════════════════════════

; Poll the state once, then read each field from the parsed JSON object.
(defpoll timer_state :interval "200ms"
  :initial '{"display":"0:00","msg":"","progress":0,"phase":"idle","color":"red"}'
  `~/.config/eww/scripts/timer-state`)

(defwidget timer-bar []
  (box :class "timer-bar timer-c-${timer_state.color} timer-p-${timer_state.phase}"
       :orientation "v"
       :space-evenly false
       :spacing 0
    (centerbox :class "timer-row" :orientation "h"
      (label :class "timer-time" :text {timer_state.display} :halign "start" :valign "center")
      (box)
      (label :class "timer-msg"  :text {timer_state.msg} :halign "end" :valign "center"
             :visible {strlength(timer_state.msg) > 0}))
    (progress :class "timer-progress"
              :value {timer_state.progress}
              :orientation "h")))

(defwindow timer
  :monitor "DP-4"
  :geometry (geometry :x "0px" :y "0px" :width "1440px" :height "140px" :anchor "top center")
  :stacking "fg"
  :exclusive true
  :focusable false
  :namespace "timer"
  (timer-bar))

; ═════════════════════════════════════════════════════════
; ── Household HUD — focus board (two columns) ────────────
; Project groups packed across two columns by height (`hud board` picks the
; break) — your FOCUS, with live Claude Code activity painted on as an animated
; spinner + drift badges. Every item lives under its project; reading order is
; work, then live projects by recency, then declared-but-idle. Each zone is fed
; by hud-board-render <zone>, polled fast so the spinner animates. (backlog
; zone exists in `hud board` but is off the panel for now.)
;
; TODAY strip: the council's day plan (itinerary zone), one clickable row per
; item — click checks it off via `hud itinerary-done <n>` and drops the board
; cache so the ✓ shows on the next poll.
; ═════════════════════════════════════════════════════════
(defpoll board_left  :interval "150ms" :initial "…" `~/.config/eww/scripts/hud-board-render left`)
(defpoll board_right :interval "150ms" :initial "…" `~/.config/eww/scripts/hud-board-render right`)
(defpoll board_today :interval "2s"    :initial "[]" `~/.config/eww/scripts/hud-today-json`)

(defwidget hud-zone [class body]
  (box :class "hud-zone ${class}" :orientation "v" :space-evenly false :hexpand true :valign "start"
    (label :class "hud-body" :markup body :halign "start" :wrap true)))

(defwidget hud-today []
  (box :class "hud-today" :orientation "v" :space-evenly false
       :visible {arraylength(board_today) > 0}
    (label :class "today-header" :text "TODAY" :halign "start")
    (for it in board_today
      (eventbox :cursor "pointer"
                :onclick "/home/curator/workspace/hud/hud itinerary-done ${it.i} >/dev/null 2>&1; rm -f ~/.local/state/hud/board.json &"
        (label :class {it.done ? "today-item done" : "today-item"}
               :halign "start"
               :text "${it.done ? "✓" : "○"}  ${it.text}")))))

(defwidget hud-panel []
  (box :class "hud-panel" :orientation "v" :space-evenly false :spacing 10
    (hud-today)
    (box :orientation "h" :space-evenly true :spacing 40
      (hud-zone :class "zone-left"  :body board_left)
      (hud-zone :class "zone-right" :body board_right))))

(defwindow hud
  :monitor "DP-4"
  :geometry (geometry :x "0px" :y "0px" :width "1440px" :anchor "top center")
  :stacking "fg"
  :exclusive true
  :focusable false
  :namespace "hud"
  (hud-panel))
