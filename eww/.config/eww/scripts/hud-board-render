#!/usr/bin/env bash
# Per-zone renderer for the HUD focus board. Arg 1 = zone (today|left|right).
# Output is Pango markup: text html-escaped, headers/items tinted per project.
# The expensive scan (hud board) is cached ~3s; zones poll fast so the braille
# spinner animates.
zone="${1:-left}"
cache="$HOME/.local/state/hud/board.json"
hud=/home/curator/workspace/hud/hud

if [ ! -f "$cache" ] || [ "$(( $(date +%s) - $(stat -c %Y "$cache" 2>/dev/null || echo 0) ))" -ge 3 ]; then
  "$hud" board >"$cache.tmp" 2>/dev/null && mv "$cache.tmp" "$cache"
  find "$HOME/.local/state/hud/active" -type f -mtime +1 -delete 2>/dev/null
fi

frames=(⠋ ⠙ ⠹ ⠸ ⠼ ⠴ ⠦ ⠧ ⠇ ⠏)
sp="${frames[$(( ($(date +%s%N) / 100000000) % 10 ))]}"

jq -r --arg z "$zone" --arg sp "$sp" '
  def col($p):
    if   $p == "dynasty"   then "#c0504d"
    elif $p == "calliope"  then "#5566cc"
    elif $p == "household" then "#dcc05a"
    elif $p == "council"   then "#eaeaf0"
    elif $p == "hud"       then "#7aa2f7"
    elif $p == "ship"      then "#5aa07a"
    else "" end;
  def tint($p; $s):
    (col($p)) as $c
    | if $c == "" then $s else "<span foreground=\"" + $c + "\">" + $s + "</span>" end;
  .[$z][]? |
  if   .kind == "header"     then tint(.project // ""; (.text|@html))
  elif .kind == "blank"      then "<span size=\"50%\"> </span>"
  elif .kind == "gap"        then "<span size=\"10%\"> </span>"
  elif .kind == "sub"        then tint(.project // ""; "    └ " + (if .working then $sp else "·" end) + " " + (.text|@html))
  elif .kind == "note"       then "<span alpha=\"55%\">    └ " + (.badge|@html) + " · " + (.text|@html) + "</span>"
  elif .kind == "alsoactive" then (if .working then $sp else "·" end) + "  " + (.text|@html)
  else
    tint(.project // "";
      ((if .working then $sp elif .done then "✓" else "○" end) + "  " + (.text|@html))
      + (if .badge then "   · " + (.badge|@html) else "" end))
  end' "$cache" 2>/dev/null
