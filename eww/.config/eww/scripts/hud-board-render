#!/usr/bin/env bash
# Per-zone renderer for the HUD focus board. Arg 1 = zone (today|left|right).
# Output is Pango markup: text html-escaped, every line painted with the colour
# `hud board` resolved for its project. Either column can hold any project (hud
# packs them by height), so the zones themselves are neutral and each line
# carries its own tint. Long lines arrive pre-wrapped, as an item/sub/note plus
# indented `cont` rows — hud owns the width budget, this script never re-flows.
# The expensive scan (hud board) is cached ~3s; zones poll fast so the braille
# spinner animates.
zone="${1:-left}"
cache="$HOME/.local/state/hud/board.json"
hud=/home/curator/workspace/hud/hud

if [ ! -f "$cache" ] || [ "$(( $(date +%s) - $(stat -c %Y "$cache" 2>/dev/null || echo 0) ))" -ge 3 ]; then
  "$hud" board >"$cache.tmp" 2>/dev/null && mv "$cache.tmp" "$cache"
  find "$HOME/.local/state/hud/active" -type f -mtime +1 -delete 2>/dev/null
fi

frames=(⠋ ⠙ ⠹ ⠸ ⠼ ⠴ ⠦ ⠧ ⠇ ⠏)
sp="${frames[$(( ($(date +%s%N) / 100000000) % 10 ))]}"

jq -r --arg z "$zone" --arg sp "$sp" '
  # One span carrying both attributes; no span at all when neither applies.
  def paint($c; $dim; $s):
    ((if $c == "" then "" else " foreground=\"" + $c + "\"" end)
     + (if $dim then " alpha=\"55%\"" else "" end)) as $attrs
    | if $attrs == "" then $s else "<span" + $attrs + ">" + $s + "</span>" end;
  def dot:  if .working then $sp elif .done then "✓" else "○" end;
  def live: if .working then $sp else "·" end;
  .[$z][]? | (.color // "") as $c |
  if   .kind == "blank"      then "<span size=\"50%\"> </span>"
  elif .kind == "gap"        then "<span size=\"10%\"> </span>"
  elif .kind == "header"     then paint($c; false;        (.text|@html))
  elif .kind == "cont"       then paint($c; .dim // false; (.text|@html))
  elif .kind == "sub"        then paint($c; false; "    └ " + live + " " + (.text|@html))
  elif .kind == "note"       then paint($c; true;  "    └ " + (.badge|@html) + " · " + (.text|@html))
  elif .kind == "alsoactive" then paint($c; false; live + "  " + (.text|@html))
  else paint($c; false; dot + "  " + (.text|@html)
                        + (if .badge then "   · " + (.badge|@html) else "" end))
  end' "$cache" 2>/dev/null
