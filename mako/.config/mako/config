# Mako notification daemon config - Cyber theme

# Style
font=Hack Nerd Font 12
background-color=#0A131CE6
text-color=#A0B4C5
border-color=#3D6390
border-size=2
border-radius=4
padding=12
margin=10

# Layout
width=350
height=150
anchor=top-right
default-timeout=5000
ignore-timeout=0
# Pin notifications to the main monitor (bottom center, landscape) instead of
# following the focused output. Appended to mako config after each theme swap —
# must be concatenated BEFORE the category snippets, since options after a
# [criteria] section header stop being global.
# Edited by hand? Also edit ~/.dotfiles/bin/.bin/theme-switcher.sh.
output=DP-3

# Override the per-theme 5s default; category overrides below still win.
default-timeout=10000
# Timer category overrides — appended to mako config after each theme swap.
# Matches the tokyo-night palette used by the eww timer bar so the bar and
# notification share a visual identity regardless of the active mako theme.
# Edited by hand? Also edit ~/.dotfiles/bin/.bin/theme-switcher.sh which
# concatenates this onto the destination after the per-theme mako.conf copy.

[category=timer-red]
border-color=#f7768e

[category=timer-green]
border-color=#9ece6a

[category=timer-yellow]
border-color=#e0af68

[category=timer-blue]
border-color=#7aa2f7

[category=timer-purple]
border-color=#bb9af7

[category=timer-cyan]
border-color=#7dcfff
# Household category overrides — appended to mako config after each theme swap.
# Same pattern as timer-categories.conf: per-agent border color so household
# notifications carry the agent's visual identity regardless of theme.
# Edited by hand? Also edit ~/.dotfiles/bin/.bin/theme-switcher.sh which
# concatenates this onto the destination after the per-theme mako.conf copy.
#
# Per-criteria style overrides for household notifications only (last matching
# criteria wins, and this file is appended last). 12s timeout so agent reminders
# are readable; wider + smaller font so long bodies read as a block instead of a
# tall skinny column; height is a hard ceiling (mako has no scroll) sized to fit
# that shape.

[category=household.tactical]
border-color=#ffffff
default-timeout=12000
width=480
font=Hack Nerd Font 10
height=350

[category=household.io]
border-color=#7aa2f7
default-timeout=12000
width=480
font=Hack Nerd Font 10
height=350

[category=household.frederica]
border-color=#9ece6a
default-timeout=12000
width=480
font=Hack Nerd Font 10
height=350
